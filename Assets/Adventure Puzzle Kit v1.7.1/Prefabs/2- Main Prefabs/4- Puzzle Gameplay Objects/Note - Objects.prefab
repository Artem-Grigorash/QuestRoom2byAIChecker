--- !u!114 &4089171406310262867
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4119648643472943347}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 82e75c414a9c17440be732db84aba36b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _isReadable: 1
  pageImage: {fileID: 21300000, guid: 817357d073873ea439bbfc8c54c3b3a1, type: 3}
  pageScale: {x: 900, y: 900}
  hasMultPages: 1
  noteText:
  - "They told us the lighthouse was decommissioned in '73. But the door was still
    warm when we found it. Someone \u2014 or something \u2014 had been here not long
    before us. The logs inside were missing, torn from their bindings. Only a smear
    of rust and saltwater remained on the desk."
  - "We found carvings under the floorboards \u2014 coordinates, etched over and
    over again like a mantra. One of the crew, Ellis, swears he saw a figure on the
    rocks that night. Tall. Still. Watching. We joked at first, but the laughter
    died quickly. Even the gulls were silent."
  - "Last night, the beacon lit itself. No power, no crew. Just an eye in the fog,
    sweeping the sea. I can\u2019t tell if it\u2019s trying to warn us... or lure
    something in. We\u2019re leaving at dawn \u2014 if dawn still comes."
  noteTextAreaScale: {x: 495, y: 795}
  textSize: 25
  fontType: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  fontColor: {r: 0, g: 0, b: 0, a: 1}
  _allowAudioPlayback: 0
  playOnOpen: 1
  noteReadAudio: {fileID: 11400000, guid: a02a5df0f1996c94fae942c678d1b0de, type: 2}
  noteFlipAudio: {fileID: 11400000, guid: 68cdad24c91e7ca4e844d2fc1ffc0ce1, type: 2}
  _isNoteTrigger: 0
  triggerObject: {fileID: 0}
